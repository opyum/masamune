# PostgreSQL
POSTGRES_USER=masamune
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# URLs
API_EXTERNAL_URL=http://localhost:9999
