# Google OAuth (optional)
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase Keys
SUPABASE_ANON_KEY=CHANGE_ME
SUPABASE_SERVICE_KEY=CHANGE_ME

# Umami
UMAMI_APP_SECRET=CHANGE_ME_RANDOM_STRING

# Stripe
